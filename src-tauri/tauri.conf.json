{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Mosaic",
  "version": "0.1.3",
  "identifier": "com.mosaic.app",
  "build": {
    "beforeDevCommand": "pnpm dev:web",
    "beforeBuildCommand": "pnpm build:web",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mosaic",
        "width": 1000,
        "height": 720,
        "minWidth": 900,
        "minHeight": 640,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "shortDescription": "Video contact sheet and screenshot generator",
    "longDescription": "Mosaic generates video contact sheets, screenshots, animated preview reels, and animated contact sheets from video files. Features drag-and-drop batch queue with live progress, cancel support, and a per-file MediaInfo metadata viewer. Requires ffmpeg and MediaInfo CLI installed separately.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "assets/fonts/DejaVuSans.ttf"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJERENGQzY3MTQwMEE1RUMKUldUc3BRQVVaL3pjTFRkbEFoNzB1Z29EM3dFd0lGeWR3SlVURzk4UXFiMGJHclBrbURlY1I1RlQK",
      "endpoints": [
        "https://github.com/mosaicvideo/mosaic/releases/latest/download/latest.json"
      ]
    }
  }
}
