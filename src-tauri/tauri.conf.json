{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Mosaic",
  "version": "0.1.0",
  "identifier": "com.mosaic.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "Mosaic",
        "width": 1000,
        "height": 720,
        "minWidth": 900,
        "minHeight": 640,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "resources": ["assets/fonts/DejaVuSans.ttf"]
  }
}
