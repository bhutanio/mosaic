{
  "name": "mosaic",
  "version": "0.1.3",
  "private": true,
  "type": "module",
  "description": "Cross-platform desktop app for generating video contact sheets, screenshots, animated preview reels, and animated contact sheets",
  "author": "Abi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mosaicvideo/mosaic.git"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "tauri": "tauri",
    "dev": "tauri dev",
    "build": "tauri build",
    "dev:web": "vite",
    "build:web": "vite build",
    "dev:cli": "cargo run --manifest-path src-tauri/Cargo.toml --bin mosaic-cli --features cli --",
    "version:bump": "node scripts/bump-version.mjs",
    "sync:defaults": "node scripts/sync-defaults.mjs"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "vite": "^8.0.8"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-store": "^2.4.2",
    "@tauri-apps/plugin-updater": "^2.10.1"
  }
}
